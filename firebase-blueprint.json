{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "description": "User email address" },
        "role": { "type": "string", "enum": ["User", "Admin"], "description": "User role" },
        "status": { "type": "string", "enum": ["Active", "Blocked"], "description": "User account status" },
        "lastActive": { "type": "string", "format": "date-time", "description": "Last activity timestamp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "name", "email", "role", "status"]
    },
    "otps": {
      "title": "OTP",
      "description": "Temporary OTP for password reset",
      "type": "object",
      "properties": {
        "otp": { "type": "string", "description": "6-digit code" },
        "expiresAt": { "type": "number", "description": "Expiration timestamp" }
      },
      "required": ["otp", "expiresAt"]
    },
    "adminAccessLogs": {
      "title": "Admin Access Log",
      "description": "Information about a user attempting to access the admin dashboard",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email" },
        "name": { "type": "string", "description": "User name" },
        "role": { "type": "string", "enum": ["User", "Admin"], "description": "User role at time of attempt" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of access" },
        "success": { "type": "boolean", "description": "Whether the access was successful" },
        "reason": { "type": "string", "enum": ["AUTHORIZED", "UNAUTHORIZED"], "description": "Reason for access status" },
        "attemptCount": { "type": "number", "description": "Total attempts by this user" }
      },
      "required": ["uid", "email", "timestamp", "success", "reason", "attemptCount"]
    },
    "userActivityLogs": {
      "title": "User Activity Log",
      "description": "Logs of general user activities",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email" },
        "name": { "type": "string", "description": "User name" },
        "action": { "type": "string", "description": "Action performed" },
        "details": { "type": "string", "description": "Additional details" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of activity" }
      },
      "required": ["uid", "email", "action", "timestamp"]
    },
    "auditLogs": {
      "title": "Security Audit Log",
      "description": "Logs for security-related events and intrusion detection",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "name": { "type": "string", "description": "User name" },
        "email": { "type": "string", "description": "User email" },
        "action": { "type": "string", "description": "Action performed (e.g. Admin Dashboard Access)" },
        "status": { "type": "string", "enum": ["SUCCESS", "WARNING", "ERROR"], "description": "Log status" },
        "message": { "type": "string", "description": "Detailed log message" },
        "attempts": { "type": "number", "description": "Attempt count" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Server timestamp" }
      },
      "required": ["uid", "name", "email", "action", "status", "message", "attempts", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document"
    },
    "/otps/{email}": {
      "schema": "otps",
      "description": "Temporary OTP document"
    },
    "/adminAccessLogs/{logId}": {
      "schema": "adminAccessLogs",
      "description": "Logs of attempts to access the admin dashboard"
    },
    "/userActivityLogs/{logId}": {
      "schema": "userActivityLogs",
      "description": "Logs of user activities"
    },
    "/auditLogs/{logId}": {
      "schema": "auditLogs",
      "description": "Security audit logs"
    }
  }
}
